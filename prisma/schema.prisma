generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  subdomain String?  @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  categories Category[]
  dishes     Dish[]
  menuStyle  MenuStyle?
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dishes Dish[]

  @@index([tenantId])
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  available   Boolean  @default(true)
  order       Int      @default(0)
  categoryId  String
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([tenantId])
}

model MenuStyle {
  id               String  @id @default(cuid())
  tenantId         String  @unique
  template         String  @default("classic")
  primaryColor     String  @default("#1a1a1a")
  secondaryColor   String  @default("#f5f5f5")
  accentColor      String  @default("#d4a574")
  backgroundColor  String  @default("#ffffff")
  fontFamily       String  @default("inter")
  headingFont      String  @default("playfair")
  layout           String  @default("grid")
  cardStyle        String  @default("elevated")
  borderRadius     String  @default("medium")
  spacing          String  @default("cozy")
  showImages       Boolean @default(true)
  showDescriptions Boolean @default(true)
  priceStyle       String  @default("inline")
  headerStyle      String  @default("centered")
  dividerStyle     String  @default("line")
  currency         String  @default("$")
  tagline          String?
  logoUrl          String?
  coverImageUrl    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
